<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Convite Maria Liz</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            
            /* Ajustado para .png */
            background-image: url('fundo.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
            background-color: #fce4ec; /* Cor de fundo caso a imagem falhe */
        }
        .container {
            position: relative;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            border-radius: 15px;
            overflow: hidden;
            background-color: white;
        }
        .container img {
            width: 100%;
            display: block;
        }
        .btn {
            position: absolute;
            width: 15%;  
            height: 10%; 
            border-radius: 50%;
            cursor: pointer;
            text-decoration: none;
            /* background: rgba(255, 0, 0, 0.3); */ /* Remova o comentário para testar o clique */
        }

        /* Posicionamento dos botões conforme seu projeto */
        #btn-local {
            left: 23%;
            bottom: 20.5%;
        }
        #btn-confirmar {
            left: 42%;
            bottom: 20.5%;
        }
        #btn-presente {
            left: 61%;
            bottom: 20.5%;
        }
    </style>
</head>
<body>

<div class="container">
    <img src="convitemaria.png" alt="Convite Maria Liz">

    <a href="https://maps.app.goo.gl/uC6mjtrPqPzcViEA7" target="_blank" class="btn" id="btn-local" title="Localização"></a>
    <a href="https://forms.gle/LzbDTu873r8hxgs4A" target="_blank" class="btn" id="btn-confirmar" title="Confirmar Presença"></a>
    
    <a href="presente.png" target="_blank" class="btn" id="btn-presente" title="Sugestão de Presente"></a>
</div>

</body>
</html>
